const express = require("express");
const path = require("path");
const mongoose = require("mongoose");
const passport = require("passport");
const LocalStrategy = require("passport-local").Strategy;
const session = require("express-session");
const bcrypt = require("bcryptjs");
const cors = require("cors");

const app = express();
const PORT = 3000;

// Admin schema/model
const AdminSchema = new mongoose.Schema({
  username: String,
  password: String,
  isAdmin: { type: Boolean, default: true }
});
const Admin = mongoose.model("Admin", AdminSchema);

// Pending Admin schema/model
const PendingAdminSchema = new mongoose.Schema({
  username: String,
  password: String,
  requestedAt: { type: Date, default: Date.now }
});
const PendingAdmin = mongoose.model("PendingAdmin", PendingAdminSchema);

// Login attempt schema/model
const LoginAttemptSchema = new mongoose.Schema({
  username: String,
  success: Boolean,
  timestamp: { type: Date, default: Date.now }
});
const LoginAttempt = mongoose.model("LoginAttempt", LoginAttemptSchema);

// Modelos
const noticiasSchema = new mongoose.Schema({
  titulo: String,
  conteudo: String,
  data: { type: Date, default: Date.now }
});
const noticias = mongoose.model("noticias", noticiasSchema);

const contatoSchema = new mongoose.Schema({
  nome: String,
  email: String
});
const contato = mongoose.model("contato", contatoSchema);

const docenteSchema = new mongoose.Schema({
  nome: String,
  materia: String
});
const docente = mongoose.model("docente", docenteSchema);

const alunosSchema = new mongoose.Schema({
  semanaProvas: String,
  gincana: String,
  feiraCiencias: String,
  semanaCultural: String,
  ferias: String
});
const alunos = mongoose.model("alunos", alunosSchema);

const responsaveisSchema = new mongoose.Schema({
  semanaProvas: String,
  gincana: String,
  feiraCiencias: String,
  semanaCultural: String,
  ferias: String,
  reuniaoPais: String,
  entregaBoletins: String
});
const responsaveis = mongoose.model("responsaveis", responsaveisSchema);

const cursosSchema = new mongoose.Schema({
  nome: String,
  descricao: String
});
const cursos = mongoose.model("cursos", cursosSchema);

let sobreText = "Texto padrão sobre a escola";
let noticiasPadrao = [{ titulo: "Nenhuma notícia cadastrada", conteudo: "Em breve novidades." }];
let docentesPadrao = [{ nome: "Nenhum docente cadastrado", materia: "" }];
let contatosPadrao = [{ nome: "Nenhum contato cadastrado", email: "" }];
let alunosPadrao = { semanaProvas: "", gincana: "", feiraCiencias: "", semanaCultural: "", ferias: "" };
let responsaveisPadrao = { semanaProvas: "", gincana: "", feiraCiencias: "", semanaCultural: "", ferias: "", reuniaoPais: "", entregaBoletins: "" };

// Passport config
app.use(passport.initialize());
app.use(passport.session());


// Login: só permite admins já aprovados
passport.use(new LocalStrategy(async (username, password, done) => {
  const user = await Admin.findOne({ username });
  if (!user) return done(null, false, { message: "Usuário não encontrado" });
  const match = await bcrypt.compare(password, user.password);
  if (!match) return done(null, false, { message: "Senha incorreta" });
  return done(null, user);
}));

passport.serializeUser((user, done) => done(null, user.id));
passport.deserializeUser(async (id, done) => {
  const user = await Admin.findById(id);
  done(null, user);
});

// Servir arquivos estáticos
app.use(express.static(path.join(__dirname, "public")));
app.use('/css', express.static(path.join(__dirname, 'css')));

// Rotas de registro
app.post("/register", async (req, res) => {
  const { username, password, confirmPassword } = req.body;
  if (password !== confirmPassword) {
    return res.status(400).send("As senhas não coincidem.");
  }
  const exists = await Admin.findOne({ username });
  const pendingExists = await PendingAdmin.findOne({ username });
  if (exists) return res.status(400).send("Usuário já existe.");
  if (pendingExists) {
    req.session.pendenteId = pendingExists._id;
    return res.redirect("/aguardando");
  }
  const hash = await bcrypt.hash(password, 10);
  const pendente = await PendingAdmin.create({ username, password: hash });
  req.session.pendenteId = pendente._id;
  res.redirect("/aguardando");
});

// Rotas de login
app.post("/login", async (req, res, next) => {
  passport.authenticate("local", async (err, user, info) => {
    await LoginAttempt.create({
      username: req.body.username,
      success: !!user,
      timestamp: new Date()
    });

    if (err) return next(err);
    if (!user) {
      // Redireciona para login com erro
      return res.redirect("/login?error=1");
    }
    req.logIn(user, (err) => {
      if (err) return next(err);
      return res.redirect("/dashboard");
    });
  })(req, res, next);
});

// Rotas para páginas
app.get("/login", (req, res) => {
  res.sendFile(path.join(__dirname, "views", "login.html"));
});
app.get("/register", (req, res) => {
  res.sendFile(path.join(__dirname, "views", "register.html"));
});
app.get("/dashboard", (req, res) => {
  if (!req.isAuthenticated()) return res.redirect("/login");
  res.sendFile(path.join(__dirname, "views", "dashboard.html"));
});
app.get("/", (req, res) => res.redirect("/login"));
app.get("/aguardando", (req, res) => {
  res.sendFile(path.join(__dirname, "views", "aguardando.html"));
});

// Novas rotas para gerenciar pendentes
function requireAdmin(req, res, next) {
  if (!req.isAuthenticated() || !req.user || !req.user.isAdmin) {
    return res.status(403).send("Acesso negado");
  }
  next();
}

app.get('/api/pendentes', requireAdmin, async (req, res) => {
  const pendentes = await PendingAdmin.find({});
  res.json(pendentes);
});
// NOTÍCIAS
app.post('/api/noticias', requireAdmin, async (req, res) => {
