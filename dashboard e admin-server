<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <h2>Painel Administrativo</h2>
  <form id="sobreForm">
    <h3>Sobre a Escola</h3>
    <textarea id="sobreText" name="sobreText"></textarea>
    <button type="submit">Salvar</button>
  </form>
  <form id="form-noticia">
    <h3>Notícias</h3>
    <input type="text" name="titulo" placeholder="Título" required>
    <textarea name="conteudo" placeholder="Conteúdo" required></textarea>
    <button type="submit">Cadastrar Notícia</button>
  </form>
  <form id="contatosForm">
    <h3>Contatos</h3>
    <input type="text" id="contatoNome" name="contatoNome" placeholder="Nome">
    <input type="email" id="contatoEmail" name="contatoEmail" placeholder="Email">
    <button type="submit">Salvar Contato</button>
  </form>
  <form id="docentesForm">
    <h3>Docentes</h3>
    <input type="text" id="docenteNome" name="docenteNome" placeholder="Nome">
    <input type="text" id="docenteMateria" name="docenteMateria" placeholder="Matéria">
    <button type="submit">Salvar Docente</button>
  </form>
  <form id="alunosForm">
    <h3>Informações para Alunos</h3>
    <input type="text" id="semanaProvasAluno" name="semanaProvasAluno" placeholder="Semana de Provas">
    <input type="text" id="gincanaAluno" name="gincanaAluno" placeholder="Eventos Esportivos">
    <input type="text" id="feiraAluno" name="feiraAluno" placeholder="Feira de Ciências">
    <input type="text" id="culturalAluno" name="culturalAluno" placeholder="Semana Cultural">
    <input type="text" id="feriasAluno" name="feriasAluno" placeholder="Férias Escolares">
    <button type="submit">Salvar Informações de Alunos</button>
  </form>
  <form id="responsaveisForm">
    <h3>Informações para Responsáveis</h3>
    <input type="text" id="semanaProvasResp" name="semanaProvasResp" placeholder="Semana de Provas">
    <input type="text" id="gincanaResp" name="gincanaResp" placeholder="Eventos Esportivos">
    <input type="text" id="feiraResp" name="feiraResp" placeholder="Feira de Ciências">
    <input type="text" id="culturalResp" name="culturalResp" placeholder="Semana Cultural">
    <input type="text" id="feriasResp" name="feriasResp" placeholder="Férias Escolares">
    <input type="text" id="reuniaoResp" name="reuniaoResp" placeholder="Reunião de Pais">
    <input type="text" id="boletinsResp" name="boletinsResp" placeholder="Entrega de Boletins">
    <button type="submit">Salvar Informações de Responsáveis</button>
  </form>
  <form id="cursosForm">
    <h3>Cursos</h3>
    <input type="text" id="cursoNome" name="cursoNome" placeholder="Nome do Curso">
    <textarea id="cursoDescricao" name="cursoDescricao" placeholder="Descrição"></textarea>
    <button type="submit">Salvar Curso</button>
  </form>
  <script>
    // SOBRE
    fetch('http://localhost:3000/api/sobre')
      .then(res => res.json())
      .then(data => { document.getElementById('sobreText').value = data.sobreText; });
    document.getElementById('sobreForm').addEventListener('submit', function(e) {
      e.preventDefault();
      fetch('http://localhost:3000/api/sobre', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sobreText: document.getElementById('sobreText').value })
      }).then(res => res.json()).then(() => { alert('Texto "Sobre" atualizado!'); });
    });

    // NOTÍCIAS
    document.getElementById('form-noticia').addEventListener('submit', function(e) {
      e.preventDefault();
      fetch('http://localhost:3000/api/noticias', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          titulo: this.titulo.value,
          conteudo: this.conteudo.value
        })
      }).then(res => res.json()).then(() => { alert('Notícia cadastrada!'); this.reset(); });
    });

    // CONTATOS
    document.getElementById('contatosForm').addEventListener('submit', function(e) {
      e.preventDefault();
      fetch('http://localhost:3000/api/contatos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nome: document.getElementById('contatoNome').value,
          email: document.getElementById('contatoEmail').value
        })
      }).then(res => res.json()).then(() => { alert('Contato salvo!'); this.reset(); });
    });

    // DOCENTES
    document.getElementById('docentesForm').addEventListener('submit', function(e) {
      e.preventDefault();
      fetch('http://localhost:3000/api/docentes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nome: document.getElementById('docenteNome').value,
          materia: document.getElementById('docenteMateria').value
        })
      }).then(res => res.json()).then(() => { alert('Docente salvo!'); this.reset(); });
    });

    // ALUNOS
    document.getElementById('alunosForm').addEventListener('submit', function(e) {
      e.preventDefault();
      fetch('http://localhost:3000/api/alunos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          semanaProvas: document.getElementById('semanaProvasAluno').value,
          gincana: document.getElementById('gincanaAluno').value,
          feiraCiencias: document.getElementById('feiraAluno').value,
          semanaCultural: document.getElementById('culturalAluno').value,
          ferias: document.getElementById('feriasAluno').value
        })
      }).then(res => res.json()).then(() => { alert('Informações de alunos salvas!'); this.reset(); });
    });

    // RESPONSÁVEIS
    document.getElementById('responsaveisForm').addEventListener('submit', function(e) {
      e.preventDefault();
      fetch('http://localhost:3000/api/responsaveis', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          semanaProvas: document.getElementById('semanaProvasResp').value,
          gincana: document.getElementById('gincanaResp').value,
          feiraCiencias: document.getElementById('feiraResp').value,
          semanaCultural: document.getElementById('culturalResp').value,
          ferias: document.getElementById('feriasResp').value,
          reuniaoPais: document.getElementById('reuniaoResp').value,
          entregaBoletins: document.getElementById('boletinsResp').value
        })
      }).then(res => res.json()).then(() => { alert('Informações de responsáveis salvas!'); this.reset(); });
    });

    // CURSOS
    document.getElementById('cursosForm').addEventListener('submit', function(e) {
      e.preventDefault();
      fetch('http://localhost:3000/api/cursos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nome: document.getElementById('cursoNome').value,
          descricao: document.getElementById('cursoDescricao').value
        })
      }).then(res => res.json()).then(() => { alert('Curso cadastrado!'); this.reset(); });
    });
  </script>
</body>
</html>



