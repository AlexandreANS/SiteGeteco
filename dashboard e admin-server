});

// CONTATOS
app.post('/api/contatos', requireAdmin, async (req, res) => {
  const { nome, email } = req.body;
  await contato.create({ nome, email });
  res.json({ success: true });
});
app.get('/api/contatos', async (req, res) => {
  const lista = await contato.find({});
  res.json(lista);
});

// ALUNOS
app.post('/api/alunos', requireAdmin, async (req, res) => {
  await alunos.deleteMany({});
  await alunos.create(req.body);
  res.json({ success: true });
});
app.get('/api/alunos', async (req, res) => {
  const info = await alunos.findOne({});
  res.json(info || {});
});

// RESPONSÁVEIS
app.post('/api/responsaveis', requireAdmin, async (req, res) => {
  await responsaveis.deleteMany({});
  await responsaveis.create(req.body);
  res.json({ success: true });
});
app.get('/api/responsaveis', async (req, res) => {
  const info = await responsaveis.findOne({});
  res.json(info || {});
});

app.post('/api/pendentes/aceitar', requireAdmin, async (req, res) => {
  if (!req.isAuthenticated()) return res.status(401).send("Não autorizado");
  const { id } = req.body;
  const pendente = await PendingAdmin.findById(id);
  if (pendente) {
    await Admin.create({ username: pendente.username, password: pendente.password });
    await PendingAdmin.findByIdAndDelete(id);

    // Se o usuário pendente está na sessão, redirecione
    if (req.session.pendenteId && req.session.pendenteId == id) {
      req.session.pendenteId = null;
      return res.json({ redirect: "/dashboard?accepted=1" });
    }
    res.json({ success: true });
  } else {
    res.status(404).send("Pendente não encontrado");
  }
});

app.post('/api/pendentes/negar', requireAdmin, async (req, res) => {
  if (!req.isAuthenticated()) return res.status(401).send("Não autorizado");
  const { id } = req.body;
  await PendingAdmin.findByIdAndDelete(id);

  // Se o usuário pendente está na sessão, redirecione
  if (req.session.pendenteId && req.session.pendenteId == id) {
    req.session.pendenteId = null;
    return res.json({ redirect: "/register?denied=1" });
  }
  res.json({ success: true });
});
app.get('/api/check-pendente', async (req, res) => {
  if (!req.session.pendenteId) return res.json({ status: "none" });
  const pendente = await PendingAdmin.findById(req.session.pendenteId);
  if (pendente) return res.json({ status: "pending" });
  const aprovado = await Admin.findOne({ _id: req.session.pendenteId });
  if (aprovado) return res.json({ status: "accepted" });
  return res.json({ status: "denied" });
});

app.post('/api/clear-pendente', (req, res) => {
  req.session.pendenteId = null;
  res.json({ success: true });
});

app.get('/api/sobre', (req, res) => {
  res.json({ sobreText });
});

app.post('/api/sobre', (req, res) => {
  sobreText = req.body.sobreText || sobreText;
  res.json({ success: true, sobreText });
});

app.post('/api/cursos', requireAdmin, async (req, res) => {
  const { nome, descricao } = req.body;
  await cursos.create({ nome, descricao });
  res.json({ success: true });
});
app.get('/api/cursos', async (req, res) => {
  const lista = await cursos.find({});
  res.json(lista);
});

