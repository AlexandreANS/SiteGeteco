// DOCENTES
app.post('/api/docentes', requireAdmin, async (req, res) => {
  const { nome, materia } = req.body;
  await docente.create({ nome, materia });
  res.json({ success: true });
});
app.get('/api/docentes', async (req, res) => {
  const lista = await docente.find({});
