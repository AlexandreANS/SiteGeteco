<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Alunos - GETECO</title>
  <link rel="stylesheet" href="projetoGetecoTeste/css/style.css">
</head>
<body>
  <header>
    <nav class="navbar">
      <a href="index.html" class="logo">GETECO</a>
      <ul class="nav-links">
        <li><a href="/index">Home</a></li>
        <li><a href="/sobre">Sobre</a></li>
        <li><a href="/cursos">Cursos</a></li>
        <li><a href="/docente">Corpo Docente</a></li>
        <li><a href="/noticias">Notícias</a></li>
        <li><a href="/contato">Contato</a></li>
        <li><a href="/alunos">Alunos</a></li>
        <li><a href="/responsaveis">Responsáveis</a></li>
      </ul>
    </nav>
  </header>

  <main class="container section">
    <h2>Informações para Alunos</h2>
    <p><strong>Semana de Provas:</strong> <span id="semana-provas"></span></p>
    <p><strong>Eventos Esportivos:</strong> <span id="gincana"></span></p>
    <p><strong>Feira de Ciências:</strong> <span id="feira"></span></p>
    <p><strong>Semana Cultural:</strong> <span id="cultural"></span></p>
    <p><strong>Férias Escolares:</strong> <span id="ferias"></span></p>
  </main>

  <footer>
    <div class="container footer-container">
      <p>© 2024 Escola Exemplar. Todos os direitos reservados.</p>
    </div>
  </footer>

  <script>
    fetch("/api/config")
      .then(res => res.json())
      .then(data => {
        document.getElementById("semana-provas").textContent = data.semanaProvas;
        document.getElementById("gincana").textContent = data.eventos.gincana;
        document.getElementById("feira").textContent = data.eventos.feiraCiencias;
        document.getElementById("cultural").textContent = data.eventos.semanaCultural;
        document.getElementById("ferias").textContent = data.eventos.ferias;
      })
      .catch(err => console.error("Erro ao carregar config:", err));
  </script>
</body>
</html>